# Copy to `.env.development.local`. Auto-loaded by `next dev` only.
# Production / Vercel never reads this file.

# Supabase project URL (https://<project-ref>.supabase.co for hosted, or http://127.0.0.1:54341 for local).
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Publishable / anon key — public, safe to ship to the browser.
# NEVER paste a service-role / secret key here.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxxxxxxxx

# Where to send the user after auth completes (used to build OAuth redirect URL).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
