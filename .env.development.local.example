# Copy to `.env.development.local`. Auto-loaded by `next dev` only.
# Production / Vercel never reads this file.

# Local self-hosted Supabase (npm run db:start).
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54341

# Default local anon key — public, safe to commit. NEVER paste a service-role key here.
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# Flips on dev-only auth shortcuts. Vercel never sets this, so any
# dev-only "Sign in as Yani" UI cannot render in deployed bundles.
NEXT_PUBLIC_LOCAL_AUTOAUTH=true
